#: ui/delegates/PairedView.qml:35
#, kde-format
msgid "This device is paired"
msgstr "இச்சாதனம் இணைக்கப்பட்டுள்ளது"

#: ui/delegates/PairedView.qml:43 ui/delegates/Unreachable.qml:40
#, kde-format
msgid "Unpair"
msgstr "இணைப்பை துண்டி"

#: ui/delegates/PairRequest.qml:35
#, kde-format
msgid "This device is requesting to be paired"
msgstr "இச்சாதனம் இணைப்பைக் கோருகிறது"

#: ui/delegates/PairRequest.qml:44
#, kde-format
msgid "Accept"
msgstr "ஏற்றுக்கொள்"

#: ui/delegates/PairRequest.qml:53
#, kde-format
msgid "Reject"
msgstr "மறு"

#: ui/delegates/UnpairedView.qml:47
#, kde-format
msgid "This device is not paired"
msgstr "இச்சாதனம் இணைக்கப்படவில்லை"

#: ui/delegates/UnpairedView.qml:56
#, kde-format
msgid "Pairing request sent"
msgstr "இணைப்பு கோரிக்கை அனுப்பப்பட்டுள்ளது"

#: ui/delegates/UnpairedView.qml:60
#, kde-format
msgid "Pair"
msgstr "இணை"

#: ui/delegates/Unreachable.qml:33
#, kde-format
msgid "This device is not reachable"
msgstr "சாதனத்தைத் தொடர்புகொள்ள முடியவில்லை"

#: ui/main.qml:24
#, kde-format
msgid "KDE Connect"
msgstr "கே.டீ.யீ. கனெக்ட்"

#: ui/main.qml:44
#, kde-format
msgid "Devices"
msgstr "சாதனங்கள்"
