#: ui/GameControllerSidebar.qml:36
#, kde-format
msgid "System navigation"
msgstr "Navigácia v systéme"

#: ui/GameControllerSidebar.qml:51
#, kde-format
msgid "START button when suppressed"
msgstr "Tlačidlo START pri potlačení"

#: ui/GameControllerSidebar.qml:52
#, kde-format
msgid ""
"Handle the START button even when input is suppressed (may conflict with "
"some apps)"
msgstr ""
"Spracovať tlačidlo START aj pri potlačenom vstupe (môže kolidovať s "
"niektorými aplikáciami)"

#: ui/main.qml:17
#, kde-format
msgid "Input"
msgstr "Vstup"

#: ui/main.qml:105
#, kde-format
msgid "Input daemon is not running"
msgstr "Démon vstupu nebeží"

#: ui/main.qml:106
#, kde-format
msgid ""
"Controller and remote settings are only available when plasma-bigscreen-"
"inputhandler is running"
msgstr ""
"Nastavenia ovládača a diaľkového ovládania sú dostupné iba vtedy, keď beží "
"plasma-bigscreen-inputhandler"

#: ui/main.qml:112
#, kde-format
msgid "System Navigation"
msgstr "Navigácia v systéme"

#: ui/main.qml:113
#, kde-format
msgid ""
"Navigate the system interface with connected controllers/remotes (apps can "
"always still use them directly)"
msgstr ""
"Navigovať v systémovom rozhraní pomocou pripojených ovládačov/diaľkových "
"ovládaní (aplikácie ich vždy môžu používať priamo)"

#: ui/main.qml:130
#, kde-format
msgid "TV remote"
msgstr "Diaľkové ovládanie TV"

#: ui/main.qml:131
#, kde-format
msgid "Navigate the system interface with the connected TV remote (CEC)"
msgstr "Navigovať v systémovom rozhraní pomocou pripojeného ovládača TV (CEC)"

#: ui/main.qml:150
#, kde-format
msgid "Game Controllers"
msgstr "Herné ovládače"

#: ui/main.qml:160
#, kde-format
msgid "Game controllers"
msgstr "Herné ovládače"

#: ui/main.qml:161
#, kde-format
msgid "Use connected game controllers for system navigation"
msgstr "Použiť pripojené herné ovládače na navigáciu v systéme"

#: ui/main.qml:180
#, kde-format
msgid "Automatic input suppression"
msgstr "Automatické potlačenie vstupu"

#: ui/main.qml:181
#, kde-format
msgid "Stop controller navigation while another app is using a controller"
msgstr "Zastaviť navigáciu ovládačom, keď ovládač používa iná aplikácia"

#: ui/main.qml:201
#, kde-format
msgid "No controllers connected"
msgstr "Nie sú pripojené žiadne ovládače"

#: ui/main.qml:202
#, kde-format
msgid "Connect a game controller"
msgstr "Pripojte herný ovládač"
