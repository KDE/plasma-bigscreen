#: ui/GameControllerSidebar.qml:37
#, kde-format
msgid "System navigation"
msgstr "Navegueu pel sistema"

#: ui/GameControllerSidebar.qml:52
#, kde-format
msgid "START button when suppressed"
msgstr "Botó INICI quan s'ha suprimit"

#: ui/GameControllerSidebar.qml:53
#, kde-format
msgid ""
"Handle the START button even when input is suppressed (may conflict with "
"some apps)"
msgstr ""
"Gestiona el botó d'INICI fins i tot quan s'ha suprimit l'entrada (pot entrar "
"en conflicte amb algunes aplicacions)"

#: ui/main.qml:17
#, kde-format
msgid "Input"
msgstr "Entrada"

#: ui/main.qml:105
#, kde-format
msgid "Input daemon is not running"
msgstr "El dimoni d'entrada no s'està executant"

#: ui/main.qml:106
#, kde-format
msgid ""
"Controller and remote settings are only available when plasma-bigscreen-"
"inputhandler is running"
msgstr ""
"La configuració del controlador i el control remot només estaran disponibles "
"quan s'està executant «plasma-bigscreen-inputhandler»"

#: ui/main.qml:112
#, kde-format
msgid "System Navigation"
msgstr "Navegueu pel sistema"

#: ui/main.qml:113
#, kde-format
msgid ""
"Navigate the system interface with connected controllers/remotes (apps can "
"always still use them directly)"
msgstr ""
"Navega per la interfície del sistema amb controladors/remots connectats (les "
"aplicacions sempre poden utilitzar-los directament)"

#: ui/main.qml:130
#, kde-format
msgid "TV remote"
msgstr "Control remot de TV"

#: ui/main.qml:131
#, kde-format
msgid "Navigate the system interface with the connected TV remote (CEC)"
msgstr ""
"Navega per la interfície del sistema amb el control remot de TV connectat "
"(CEC)"

#: ui/main.qml:150
#, kde-format
msgid "Game Controllers"
msgstr "Controladors de joc"

#: ui/main.qml:160
#, kde-format
msgid "Game controllers"
msgstr "Controladors de joc"

#: ui/main.qml:161
#, kde-format
msgid "Use connected game controllers for system navigation"
msgstr "Utilitza controladors de joc connectats per a la navegació del sistema"

#: ui/main.qml:180
#, kde-format
msgid "Automatic input suppression"
msgstr "Suprimiu automàtica de l'entrada"

#: ui/main.qml:181
#, kde-format
msgid "Stop controller navigation while another app is using a controller"
msgstr ""
"Para la navegació del controlador mentre una altra aplicació utilitza un "
"controlador"

#: ui/main.qml:201
#, kde-format
msgid "No controllers connected"
msgstr "Sense cap controlador connectat"

#: ui/main.qml:202
#, kde-format
msgid "Connect a game controller"
msgstr "Connecta un controlador de joc"
