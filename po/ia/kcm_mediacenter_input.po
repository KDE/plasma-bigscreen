#: ui/GameControllerSidebar.qml:36
#, kde-format
msgid "System navigation"
msgstr "Navigation de systema"

#: ui/GameControllerSidebar.qml:51
#, kde-format
msgid "START button when suppressed"
msgstr "Button de START quando supprimite"

#: ui/GameControllerSidebar.qml:52
#, kde-format
msgid ""
"Handle the START button even when input is suppressed (may conflict with "
"some apps)"
msgstr ""
"Manea le button de START anque quando le ingresso es supprimite (il pote "
"confliger con alcun applicationes)"

#: ui/main.qml:17
#, kde-format
msgid "Input"
msgstr "Ingresso"

#: ui/main.qml:105
#, kde-format
msgid "Input daemon is not running"
msgstr "Demone de ingresso non es executante"

#: ui/main.qml:106
#, kde-format
msgid ""
"Controller and remote settings are only available when plasma-bigscreen-"
"inputhandler is running"
msgstr ""
"Controlator e preferentias remote (telecomando) es solmente disponibile "
"quando  plasma-bigscreen-inputhandler es executante"

#: ui/main.qml:112
#, kde-format
msgid "System Navigation"
msgstr "Systema de Navigation"

#: ui/main.qml:113
#, kde-format
msgid ""
"Navigate the system interface with connected controllers/remotes (apps can "
"always still use them directly)"
msgstr ""
"Naviga le interfacie de systema con controlatores/remotes (telecomandos) "
"connectite (apps pote sempre ancora usar los directemente)"

#: ui/main.qml:130
#, kde-format
msgid "TV remote"
msgstr "TV remote (telecomando de TV)"

#: ui/main.qml:131
#, kde-format
msgid "Navigate the system interface with the connected TV remote (CEC)"
msgstr ""
"Naviga le  interfacie de systema con le telecomando de TV connectite (CEC)"

#: ui/main.qml:150
#, kde-format
msgid "Game Controllers"
msgstr "Controlatores de joco"

#: ui/main.qml:160
#, kde-format
msgid "Game controllers"
msgstr "Controlatores de joco"

#: ui/main.qml:161
#, kde-format
msgid "Use connected game controllers for system navigation"
msgstr "Usa controlatores de joco connectite per navigation de systema"

#: ui/main.qml:180
#, kde-format
msgid "Automatic input suppression"
msgstr "Suppression deingresso automatic"

#: ui/main.qml:181
#, kde-format
msgid "Stop controller navigation while another app is using a controller"
msgstr ""
"Stoppa navigation de controlator durante que un altere appes usnte le "
"controlator"

#: ui/main.qml:201
#, kde-format
msgid "No controllers connected"
msgstr "Nulle controlatores connectite"

#: ui/main.qml:202
#, kde-format
msgid "Connect a game controller"
msgstr "Connecte un controlator de joco"
