#: ui/GameControllerSidebar.qml:37
#, kde-format
msgid "System navigation"
msgstr "التنقل في النظام"

#: ui/GameControllerSidebar.qml:52
#, kde-format
msgid "START button when suppressed"
msgstr "زر البداية START عند كبته"

#: ui/GameControllerSidebar.qml:53
#, kde-format
msgid ""
"Handle the START button even when input is suppressed (may conflict with "
"some apps)"
msgstr ""
"تعامل مع زر البداية START حتى عندما يكون الإدخال مكبوتًا (قد يتعارض مع بعض "
"التطبيقات)"

#: ui/main.qml:17
#, kde-format
msgid "Input"
msgstr "الإدخال"

#: ui/main.qml:105
#, kde-format
msgid "Input daemon is not running"
msgstr "خدمة الإدخال لا يعمل."

#: ui/main.qml:106
#, kde-format
msgid ""
"Controller and remote settings are only available when plasma-bigscreen-"
"inputhandler is running"
msgstr ""
"إعدادات وحدة التحكم وجهاز التحكم عن بُعد متاحة فقط عند تشغيل معالج إدخال "
"بلازما للشاشة الكبيرة."

#: ui/main.qml:112
#, kde-format
msgid "System Navigation"
msgstr "التنقل في النظام"

#: ui/main.qml:113
#, kde-format
msgid ""
"Navigate the system interface with connected controllers/remotes (apps can "
"always still use them directly)"
msgstr ""
"تنقل في واجهة النظام باستخدام وحدات التحكم/أجهزة التحكم عن بُعد المتصلة (يمكن "
"للتطبيقات دائمًا استخدامها مباشرةً)."

#: ui/main.qml:130
#, kde-format
msgid "TV remote"
msgstr "متحكم التلفاز"

#: ui/main.qml:131
#, kde-format
msgid "Navigate the system interface with the connected TV remote (CEC)"
msgstr ""
"تنقل في واجهة النظام باستخدام جهاز التحكم عن بُعد المتصل بالتلفاز (CEC)."

#: ui/main.qml:150
#, kde-format
msgid "Game Controllers"
msgstr "متحكمات الألعاب"

#: ui/main.qml:160
#, kde-format
msgid "Game controllers"
msgstr "متحكمات الألعاب"

#: ui/main.qml:161
#, kde-format
msgid "Use connected game controllers for system navigation"
msgstr "استخدم متحكمات ألعاب موصولة للتنقل في النظام."

#: ui/main.qml:180
#, kde-format
msgid "Automatic input suppression"
msgstr "كبت الإدخال آليًا"

#: ui/main.qml:181
#, kde-format
msgid "Stop controller navigation while another app is using a controller"
msgstr "أوقف التنقل بواسطة المتحكم أثناء استخدام تطبيق آخر لوحدة التحكم"

#: ui/main.qml:201
#, kde-format
msgid "No controllers connected"
msgstr "لا توجد متحكمات متصلة."

#: ui/main.qml:202
#, fuzzy, kde-format
#| msgid "Game controllers"
msgid "Connect a game controller"
msgstr "متحكمات الألعاب"

#~ msgid "Connect a game controller or TV remote (over CEC)"
#~ msgstr "صل متحكم ألعاب أو متحكم تلفاز عن بعد (عبر CEC)"
