#: contents/logout/Logout.qml:152
msgid "Installing software updates and restarting in 1 second"
msgid_plural "Installing software updates and restarting in %1 seconds"
msgstr[0] ""
"Elementen voor bijwerken van software installeren en na 1 seconde herstarten"
msgstr[1] ""
"Elementen voor bijwerken van software installeren en na %1 seconden "
"herstarten"

#: contents/logout/Logout.qml:153
msgid "Restarting in 1 second"
msgid_plural "Restarting in %1 seconds"
msgstr[0] "Na 1 seconde opnieuw opstarten"
msgstr[1] "Na %1 seconden opnieuw starten"

#: contents/logout/Logout.qml:155
msgid "Logging out in 1 second"
msgid_plural "Logging out in %1 seconds"
msgstr[0] "Na 1 seconde afmelden"
msgstr[1] "Na %1 seconden afmelden"

#: contents/logout/Logout.qml:158
msgid "Installing software updates and shutting down in 1 second"
msgid_plural "Installing software updates and shutting down in %1 seconds"
msgstr[0] ""
"Elementen voor bijwerken van software installeren en na 1 seconde afsluiten"
msgstr[1] ""
"Elementen voor bijwerken van software installeren en na %1 seconden afsluiten"

#: contents/logout/Logout.qml:159
msgid "Shutting down in 1 second"
msgid_plural "Shutting down in %1 seconds"
msgstr[0] "Afsluiten na 1 seconde."
msgstr[1] "Afsluiten na %1 seconden."

#: contents/logout/Logout.qml:174
msgid ""
"One other user is currently logged in. If the computer is shut down or "
"restarted, that user may lose work."
msgid_plural ""
"%1 other users are currently logged in. If the computer is shut down or "
"restarted, those users may lose work."
msgstr[0] ""
"Er is nog één andere gebruiker ingelogd. Als de computer wordt afgesloten of "
"opnieuw gestart, dan kan die gebruiker werk verliezen."
msgstr[1] ""
"Er zijn %1 andere gebruikers nu ingelogd. Als de computer wordt afgesloten "
"of opnieuw gestart, dan kunnen die gebruikers werk verliezen."

#: contents/logout/Logout.qml:191
msgid "When restarted, the computer will enter UEFI firmware settings."
msgstr ""
"Na het herstarten zal de computer de UEFI-firmware-instellingen ingaan."

#: contents/logout/Logout.qml:193
msgid "When restarted, the computer will enter the firmware setup screen."
msgstr "Na de herstart zal de computer naar het firmware setup scherm gaan."

#: contents/logout/Logout.qml:208
msgid "When restarted, the computer will enter the boot loader menu."
msgstr "Bij herstarten zal de computer naar het bootloader menu gaan."

#: contents/logout/Logout.qml:221
msgctxt "%1 is a boot loader entry"
msgid "When restarted, the computer will switch to %1."
msgstr "Bij herstarten zal de computer omschakelen naar %1."

