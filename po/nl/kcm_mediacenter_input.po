#: ui/GameControllerSidebar.qml:37
#, kde-format
msgid "System navigation"
msgstr "Systeemnavigatie"

#: ui/GameControllerSidebar.qml:52
#, kde-format
msgid "START button when suppressed"
msgstr "START-knop bij onderdrukt"

#: ui/GameControllerSidebar.qml:53
#, kde-format
msgid ""
"Handle the START button even when input is suppressed (may conflict with "
"some apps)"
msgstr ""
"Bedien de START-knop zelfs wanneer de invoer is onderdrukt (kan in onflict "
"zijn met sommige toepassingen)"

#: ui/main.qml:17
#, kde-format
msgid "Input"
msgstr "Invoer"

#: ui/main.qml:105
#, kde-format
msgid "Input daemon is not running"
msgstr "Invoer-daemon is niet actief"

#: ui/main.qml:106
#, kde-format
msgid ""
"Controller and remote settings are only available when plasma-bigscreen-"
"inputhandler is running"
msgstr ""
"Controller en externe instellingen zijn alleen beschikbaar wanneer de "
"invoerbehandelaar van plasma-bigscreen actief is"

#: ui/main.qml:112
#, kde-format
msgid "System Navigation"
msgstr "Systeemnavigatie"

#: ui/main.qml:113
#, kde-format
msgid ""
"Navigate the system interface with connected controllers/remotes (apps can "
"always still use them directly)"
msgstr ""
"Navigeer door het systeeminterface met aangesloten controllers/"
"afstandsbedieningen (toepassingen kunnen ze altijd nog rechtstreeks "
"gebruiken)."

#: ui/main.qml:130
#, kde-format
msgid "TV remote"
msgstr "TV op afstand"

#: ui/main.qml:131
#, kde-format
msgid "Navigate the system interface with the connected TV remote (CEC)"
msgstr ""
"Navigeer door het systeeminterface met de afstandsbediening van de "
"aangesloten tv (CEC)."

#: ui/main.qml:150
#, kde-format
msgid "Game Controllers"
msgstr "Spelcontrollers"

#: ui/main.qml:160
#, kde-format
msgid "Game controllers"
msgstr "Spelcontrollers"

#: ui/main.qml:161
#, kde-format
msgid "Use connected game controllers for system navigation"
msgstr "Gebruik aangesloten spelcontrollers voor systeemnavigatie"

#: ui/main.qml:180
#, kde-format
msgid "Automatic input suppression"
msgstr "Automatische invoeronderdrukking"

#: ui/main.qml:181
#, kde-format
msgid "Stop controller navigation while another app is using a controller"
msgstr ""
"Stop de navigatie met de controller terwijl een andere toepassing de "
"controller gebruikt"

#: ui/main.qml:201
#, kde-format
msgid "No controllers connected"
msgstr "Geen verbonden controllers"

#: ui/main.qml:202
#, fuzzy, kde-format
#| msgid "Game controllers"
msgid "Connect a game controller"
msgstr "Spelcontrollers"

#~ msgid "Connect a game controller or TV remote (over CEC)"
#~ msgstr "Sluit een spelcontroller of tv-afstandsbediening aan (via CEC)."
