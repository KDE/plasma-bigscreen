#: ui/GameControllerSidebar.qml:36
#, kde-format
msgid "System navigation"
msgstr "Navegação do sistema"

#: ui/GameControllerSidebar.qml:51
#, kde-format
msgid "START button when suppressed"
msgstr "Botão INICIAR quando suprimido"

#: ui/GameControllerSidebar.qml:52
#, kde-format
msgid ""
"Handle the START button even when input is suppressed (may conflict with "
"some apps)"
msgstr ""
"Manipular o botão INICIAR mesmo quando a entrada estiver suprimida (pode "
"entrar em conflito com alguns aplicativos)"

#: ui/main.qml:17
#, kde-format
msgid "Input"
msgstr "Entrada"

#: ui/main.qml:105
#, kde-format
msgid "Input daemon is not running"
msgstr "O daemon de entrada não está em execução"

#: ui/main.qml:106
#, kde-format
msgid ""
"Controller and remote settings are only available when plasma-bigscreen-"
"inputhandler is running"
msgstr ""
"As configurações do controlador e do controle remoto só estão disponíveis "
"quando o plasma-bigscreen-inputhandler está em execução"

#: ui/main.qml:112
#, kde-format
msgid "System Navigation"
msgstr "Navegação do sistema"

#: ui/main.qml:113
#, kde-format
msgid ""
"Navigate the system interface with connected controllers/remotes (apps can "
"always still use them directly)"
msgstr ""
"Navegue pela interface do sistema com controladores/controles remotos "
"conectados (os aplicativos ainda poderão usá-los diretamente)"

#: ui/main.qml:130
#, kde-format
msgid "TV remote"
msgstr "Controle remoto da TV"

#: ui/main.qml:131
#, kde-format
msgid "Navigate the system interface with the connected TV remote (CEC)"
msgstr ""
"Navegue pela interface do sistema com o controle remoto da TV conectada (CEC)"

#: ui/main.qml:150
#, kde-format
msgid "Game Controllers"
msgstr "Controladores de jogo"

#: ui/main.qml:160
#, kde-format
msgid "Game controllers"
msgstr "Controladores de jogo"

#: ui/main.qml:161
#, kde-format
msgid "Use connected game controllers for system navigation"
msgstr "Use os controladores de jogos conectados para navegar no sistema"

#: ui/main.qml:180
#, kde-format
msgid "Automatic input suppression"
msgstr "Supressão automática de entrada"

#: ui/main.qml:181
#, kde-format
msgid "Stop controller navigation while another app is using a controller"
msgstr ""
"Interrompa a navegação do controlador enquanto outro aplicativo estiver "
"usando o controlador"

#: ui/main.qml:201
#, kde-format
msgid "No controllers connected"
msgstr "Nenhum controlador conectado"

#: ui/main.qml:202
#, kde-format
msgid "Connect a game controller"
msgstr "Conectar um controlador de jogo"

#~ msgid "Connect a game controller or TV remote (over CEC)"
#~ msgstr "Conecte um controle de jogo ou um controle remoto de TV (via CEC)"
