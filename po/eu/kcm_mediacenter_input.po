#: ui/GameControllerSidebar.qml:36
#, kde-format
msgid "System navigation"
msgstr "Sistemaren nabigazioa"

#: ui/GameControllerSidebar.qml:51
#, kde-format
msgid "START button when suppressed"
msgstr "HASI botoia inhibituta dagoenean"

#: ui/GameControllerSidebar.qml:52
#, kde-format
msgid ""
"Handle the START button even when input is suppressed (may conflict with "
"some apps)"
msgstr ""
"HASI botoia kudeatu sarrera inhibituta dagoenean ere (aplikazio batzuekin "
"gatazka egin dezake)"

#: ui/main.qml:17
#, kde-format
msgid "Input"
msgstr "Sarrera"

#: ui/main.qml:105
#, kde-format
msgid "Input daemon is not running"
msgstr "Sarrera daimona ez da exekutatzen ari"

#: ui/main.qml:106
#, kde-format
msgid ""
"Controller and remote settings are only available when plasma-bigscreen-"
"inputhandler is running"
msgstr ""
"Kontrolagailuaren eta urruneko agintearen ezarpenak plasma-bigscreen-"
"inputhandler exekutatzen ari denean bakarrik daude erabilgarri"

#: ui/main.qml:112
#, kde-format
msgid "System Navigation"
msgstr "Sistemaren nabigazioa"

#: ui/main.qml:113
#, kde-format
msgid ""
"Navigate the system interface with connected controllers/remotes (apps can "
"always still use them directly)"
msgstr ""
"Sistemaren interfazea konektatutako kontrolagailuekin/urruneko aginteekin "
"nabigatu (aplikazioek beti zuzenean erabil ditzakete)"

#: ui/main.qml:130
#, kde-format
msgid "TV remote"
msgstr "TBren urruneko agintea"

#: ui/main.qml:131
#, kde-format
msgid "Navigate the system interface with the connected TV remote (CEC)"
msgstr ""
"Sistemaren interfazea konektatutako TBren urruneko agintearekin nabigatu "
"(CEC)"

#: ui/main.qml:150
#, kde-format
msgid "Game Controllers"
msgstr "Joko-kontrolagailuak"

#: ui/main.qml:160
#, kde-format
msgid "Game controllers"
msgstr "Joko-kontrolagailuak"

#: ui/main.qml:161
#, kde-format
msgid "Use connected game controllers for system navigation"
msgstr "Erabili konektatutako joko-kontrolatzaileak sistema nabigatzeko"

#: ui/main.qml:180
#, kde-format
msgid "Automatic input suppression"
msgstr "Sarrera automatikoki kentzea"

#: ui/main.qml:181
#, kde-format
msgid "Stop controller navigation while another app is using a controller"
msgstr ""
"Kontrolagailu bidezko nabigazioa gelditu beste aplikazio bat kontrolagailua "
"erabiltzen ari den bitartean"

#: ui/main.qml:201
#, kde-format
msgid "No controllers connected"
msgstr "Ez dago kontrolagailurik konektatuta"

#: ui/main.qml:202
#, kde-format
msgid "Connect a game controller"
msgstr "Joko-kontrolagailu bat konektatu"
