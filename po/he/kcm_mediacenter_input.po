#: ui/GameControllerSidebar.qml:37
#, kde-format
msgid "System navigation"
msgstr "ניווט במערכת"

#: ui/GameControllerSidebar.qml:52
#, kde-format
msgid "START button when suppressed"
msgstr "כפתור התחלה (START) כאשר מודחק"

#: ui/GameControllerSidebar.qml:53
#, kde-format
msgid ""
"Handle the START button even when input is suppressed (may conflict with "
"some apps)"
msgstr ""
"טיפול בכפתור התחלה (START) אפילו אם הקלט מודחק (יכול לסתור כל מיני יישומים)"

#: ui/main.qml:17
#, kde-format
msgid "Input"
msgstr "קלט"

#: ui/main.qml:105
#, kde-format
msgid "Input daemon is not running"
msgstr "סוכן הקלט לא רץ"

#: ui/main.qml:106
#, kde-format
msgid ""
"Controller and remote settings are only available when plasma-bigscreen-"
"inputhandler is running"
msgstr ""
"הגדרות הבקרים והשליטה מרחוק זמינות רק כאשר plasma-bigscreen-inputhandler פועל"

#: ui/main.qml:112
#, kde-format
msgid "System Navigation"
msgstr "ניווט במערכת"

#: ui/main.qml:113
#, kde-format
msgid ""
"Navigate the system interface with connected controllers/remotes (apps can "
"always still use them directly)"
msgstr ""
"לנווט בממשק המערכת עם בקרים/שלטים מחוברים (יישומים תמיד יכולים להשתמש בהם "
"ישירות)"

#: ui/main.qml:128
#, kde-format
msgid "TV remote"
msgstr "שלט רחוק לטלוויזיה"

#: ui/main.qml:129
#, kde-format
msgid "Navigate the system interface with the connected TV remote (CEC)"
msgstr "אפשר לנווט בממשק המערכת עם השלט הרחוק של הטלוויזיה (CEC)"

#: ui/main.qml:145
#, kde-format
msgid "Game Controllers"
msgstr "בקרי משחקים"

#: ui/main.qml:155
#, kde-format
msgid "Game controllers"
msgstr "בקרי משחקים"

#: ui/main.qml:156
#, kde-format
msgid "Use connected game controllers for system navigation"
msgstr "להשתמש בבקרי המשחקים המחוברים לניווט במערכת"

#: ui/main.qml:172
#, kde-format
msgid "Automatic input suppression"
msgstr "הדחקת קלט אוטומטית"

#: ui/main.qml:173
#, kde-format
msgid "Stop controller navigation while another app is using a controller"
msgstr "לעצור ניווט באמצעות בקר כאשר יישום אחר משתמש בבקר"

#: ui/main.qml:190
#, kde-format
msgid "No controllers connected"
msgstr "אין בקרים מחוברים"

#: ui/main.qml:191
#, kde-format
msgid "Connect a game controller or TV remote (over CEC)"
msgstr "יש לחבר בקר משחק או שלט רחוק של טלוויזיה (דרך CEC)"
