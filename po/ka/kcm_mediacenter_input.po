#: ui/GameControllerSidebar.qml:37
#, kde-format
msgid "System navigation"
msgstr "ნავიგაცია სისტემაში"

#: ui/GameControllerSidebar.qml:52
#, kde-format
msgid "START button when suppressed"
msgstr "ღილაკი START ჩახშობისას"

#: ui/GameControllerSidebar.qml:53
#, kde-format
msgid ""
"Handle the START button even when input is suppressed (may conflict with "
"some apps)"
msgstr ""
"START ღილაკის დამუშავება მაშინაც კი, როცა შეყვანა ჩახშობილია (შეიძლება, "
"კონფლიქტში შევიდეს ზოგიერთ აპლიკაციასთან)"

#: ui/main.qml:17
#, kde-format
msgid "Input"
msgstr "შეყვანა"

#: ui/main.qml:105
#, kde-format
msgid "Input daemon is not running"
msgstr "შეყვანის დემონი გაშვებული არაა"

#: ui/main.qml:106
#, kde-format
msgid ""
"Controller and remote settings are only available when plasma-bigscreen-"
"inputhandler is running"
msgstr ""
"კონტროლერის და პულტის პარამეტრები, მხოლოდ, ხელმისაწვდომია მაშინ, როცა "
"გაშვებულია plasma-bigscreen-inputhandler"

#: ui/main.qml:112
#, kde-format
msgid "System Navigation"
msgstr "ნავიგაცია სისტემაში"

#: ui/main.qml:113
#, kde-format
msgid ""
"Navigate the system interface with connected controllers/remotes (apps can "
"always still use them directly)"
msgstr ""
"სისტემის ინტერფეისში ნავიგაცია დაკავშირებული კონტროლერებით/პულტებით "
"(აპლიკაციებს ყოველთვის შეუძლიათ, ისინი პირდაპირ გამოიყენონ)"

#: ui/main.qml:130
#, kde-format
msgid "TV remote"
msgstr "ტელევიზორის პულტი"

#: ui/main.qml:131
#, kde-format
msgid "Navigate the system interface with the connected TV remote (CEC)"
msgstr "სისტემის ინტერფეისში ნავიგაცია დაკავშირებული ტელევიზორის პულტით (CEC)"

#: ui/main.qml:150
#, kde-format
msgid "Game Controllers"
msgstr "თამაშის კონტროლერები"

#: ui/main.qml:160
#, kde-format
msgid "Game controllers"
msgstr "თამაშის კონტროლერები"

#: ui/main.qml:161
#, kde-format
msgid "Use connected game controllers for system navigation"
msgstr ""
"დაკავშირებული თამაშის კონტროლერების გამოყენება სისტემაში ნავიგაციისთვის"

#: ui/main.qml:180
#, kde-format
msgid "Automatic input suppression"
msgstr "შეყვანის ავტომატური ჩახშობა"

#: ui/main.qml:181
#, kde-format
msgid "Stop controller navigation while another app is using a controller"
msgstr "კონტროლერით ნავიგაციის გაჩერება, როცა მას სხვა აპლიკაცია იყენებს"

#: ui/main.qml:201
#, kde-format
msgid "No controllers connected"
msgstr "დაკავშირებული კონტროლერების გარეშე"

#: ui/main.qml:202
#, kde-format
msgid "Connect a game controller"
msgstr "თამაშის კონტროლერის დაკავშირება"

#~ msgid "Connect a game controller or TV remote (over CEC)"
#~ msgstr "დააკავშირეთ თამაშის კონტროლერი, ან ტელევიზორის პულტი (CEC-ით)"
