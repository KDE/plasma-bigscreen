#: ui/GameControllerSidebar.qml:37
#, kde-format
msgid "System navigation"
msgstr "Sistem Dolaşımı"

#: ui/GameControllerSidebar.qml:52
#, kde-format
msgid "START button when suppressed"
msgstr "Bastırıldığında BAŞLAT düğmesi"

#: ui/GameControllerSidebar.qml:53
#, kde-format
msgid ""
"Handle the START button even when input is suppressed (may conflict with "
"some apps)"
msgstr ""
"Giriş eylemleri bastırılsa bile BAŞLAT düğmesini işle (bazı uygulamalarla "
"çakışabilir)"

#: ui/main.qml:17
#, kde-format
msgid "Input"
msgstr "Giriş"

#: ui/main.qml:105
#, kde-format
msgid "Input daemon is not running"
msgstr "Giriş ardalan süreci çalışmıyor"

#: ui/main.qml:106
#, kde-format
msgid ""
"Controller and remote settings are only available when plasma-bigscreen-"
"inputhandler is running"
msgstr ""
"Kumanda ve uzak konum ayarları yalnızca plasma-bigscreen-inputhandler "
"çalışıyorsa kullanılabilirdir"

#: ui/main.qml:112
#, kde-format
msgid "System Navigation"
msgstr "Sistem Dolaşımı"

#: ui/main.qml:113
#, kde-format
msgid ""
"Navigate the system interface with connected controllers/remotes (apps can "
"always still use them directly)"
msgstr ""
"Bağlı kumandalar/kollar ile sistem arayüzünde dolaşın (uygulamalar onları "
"her zaman doğrudan kullanabilir)"

#: ui/main.qml:128
#, kde-format
msgid "TV remote"
msgstr "TV Uzaktan Kumandası"

#: ui/main.qml:129
#, kde-format
msgid "Navigate the system interface with the connected TV remote (CEC)"
msgstr "Sistem arayüzünde bağlı TV uzaktan kumandası ile geçinin (CEC)"

#: ui/main.qml:145
#, kde-format
msgid "Game Controllers"
msgstr "Oyun Kolları"

#: ui/main.qml:155
#, kde-format
msgid "Game controllers"
msgstr "Oyun Kolları"

#: ui/main.qml:156
#, kde-format
msgid "Use connected game controllers for system navigation"
msgstr "Sistemde dolaşmak için bağlı oyun kollarını kullanın"

#: ui/main.qml:172
#, kde-format
msgid "Automatic input suppression"
msgstr "Kendiliğinden giriş bastırma"

#: ui/main.qml:173
#, kde-format
msgid "Stop controller navigation while another app is using a controller"
msgstr "Başka bir uygulama kolu kullanıyorsa kol ile dolaşımı durdur"

#: ui/main.qml:190
#, kde-format
msgid "No controllers connected"
msgstr "Hiçbir kol/kumanda bağlı değil"

#: ui/main.qml:191
#, kde-format
msgid "Connect a game controller or TV remote (over CEC)"
msgstr "Bir oyun kolu veya TV uzaktan kumandası bağlayın (CEC ile)"
