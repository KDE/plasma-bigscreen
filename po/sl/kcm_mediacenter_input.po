#: ui/GameControllerSidebar.qml:36
#, kde-format
msgid "System navigation"
msgstr "Sistemska navigacija"

#: ui/GameControllerSidebar.qml:51
#, kde-format
msgid "START button when suppressed"
msgstr "Gumb START, kadar je zatrt"

#: ui/GameControllerSidebar.qml:52
#, kde-format
msgid ""
"Handle the START button even when input is suppressed (may conflict with "
"some apps)"
msgstr ""
"Obvladovanje gumba START celo kadar je vhod zatrt (lahko pride do konflikta "
"z nekaterimi aplikacijami)"

#: ui/main.qml:17
#, kde-format
msgid "Input"
msgstr "Vhod"

#: ui/main.qml:105
#, kde-format
msgid "Input daemon is not running"
msgstr "Vhodni demon ne teče"

#: ui/main.qml:106
#, kde-format
msgid ""
"Controller and remote settings are only available when plasma-bigscreen-"
"inputhandler is running"
msgstr ""
"Nastavitve krmilnika in daljinskega upravljalnika so na voljo le, če se teče "
"plasma-bigscreen-inputhandler"

#: ui/main.qml:112
#, kde-format
msgid "System Navigation"
msgstr "Sistemska navigacija"

#: ui/main.qml:113
#, kde-format
msgid ""
"Navigate the system interface with connected controllers/remotes (apps can "
"always still use them directly)"
msgstr ""
"Navigacija po sistemskem vmesniku s povezanimi krmilniki/daljinskimi "
"upravljalniki (aplikacije jih lahko vedno uporabljajo neposredno)"

#: ui/main.qml:130
#, kde-format
msgid "TV remote"
msgstr "Daljinski upravljalnik za TV"

#: ui/main.qml:131
#, kde-format
msgid "Navigate the system interface with the connected TV remote (CEC)"
msgstr ""
"Navigacija po sistemskem vmesniku s priključenim daljinskim upravljalnikom "
"televizorja (CEC)"

#: ui/main.qml:150
#, kde-format
msgid "Game Controllers"
msgstr "Krmilniki iger"

#: ui/main.qml:160
#, kde-format
msgid "Game controllers"
msgstr "Krmilniki iger"

#: ui/main.qml:161
#, kde-format
msgid "Use connected game controllers for system navigation"
msgstr "Uporabi povezane igralne krmilnike za navigacijo po sistemu"

#: ui/main.qml:180
#, kde-format
msgid "Automatic input suppression"
msgstr "Samodejno zatiranje vhoda"

#: ui/main.qml:181
#, kde-format
msgid "Stop controller navigation while another app is using a controller"
msgstr "Ustavi navigacije krmilnika kadar druga aplikacija uporablja krmilnik"

#: ui/main.qml:201
#, kde-format
msgid "No controllers connected"
msgstr "Ni priključenih krmilnikov"

#: ui/main.qml:202
#, kde-format
msgid "Connect a game controller"
msgstr "Priklopi krmilnik iger"

#~ msgid "Connect a game controller or TV remote (over CEC)"
#~ msgstr ""
#~ "Priključi krmilnik iger ali daljinski upravljalnik televizorja (prek CEC-"
#~ "a)"
