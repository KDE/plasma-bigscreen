#: contents/logout/Logout.qml:174
msgid ""
"One other user is currently logged in. If the computer is shut down or "
"restarted, that user may lose work."
msgid_plural ""
"%1 other users are currently logged in. If the computer is shut down or "
"restarted, those users may lose work."
msgstr[0] ""
"Trenutno je prijavljenih %1 drugih uporabnikov. Če računalnik izklopite ali "
"znova zaženete, lahko ti uporabniki izgubijo svoje delo."
msgstr[1] ""
"Trenutno je prijavljen %1 drug uporabnik. Če računalnik izklopite ali znova "
"zaženete, lahko ta uporabnik izgubi svoje delo."
msgstr[2] ""
"Trenutno sta prijavljena %1 druga uporabnika. Če računalnik izklopite ali "
"znova zaženete, lahko ta uporabnika izgubita svoje delo."
msgstr[3] ""
"Trenutno je prijavljenih %1 drugih uporabnikov. Če računalnik izklopite ali "
"znova zaženete, lahko ti uporabniki izgubijo svoje delo."

#: contents/logout/Logout.qml:191
msgid "When restarted, the computer will enter UEFI firmware settings."
msgstr ""
"Ob ponovnem zagonu bo računalnik vstopil v nastavitve vdelane programske "
"opreme UEFI."

#: contents/logout/Logout.qml:193
msgid "When restarted, the computer will enter the firmware setup screen."
msgstr ""
"Ko se računalnik znova zažene, se prikaže zaslon za nastavitev vdelane "
"programske opreme."

#: contents/logout/Logout.qml:208
msgid "When restarted, the computer will enter the boot loader menu."
msgstr "Ko se računalnik znova zažene, se prikaže meni zagonskega nalagalnika."

#: contents/logout/Logout.qml:221
msgctxt "%1 is a boot loader entry"
msgid "When restarted, the computer will switch to %1."
msgstr "Ob ponovnem zagonu se bo računalnik preklopil na %1."

